/control/verbose 1
/run/verbose 1

/run/numberOfThreads 1

/det/crystal LYSO
/src/external Na22
/src/enableLu true
/src/luFrac 0.864
/src/extPosZ -0.1 mm

/out/name root/LYSO_Na22_28.5ph_abs2_SetType(dielectric_dielectric)_SetFinish(ground)_REFLECTIVITY(0.97)

/run/initialize
/process/had/rdm/thresholdForVeryLongDecayTime 1.e+60 year
/run/beamOn 50000